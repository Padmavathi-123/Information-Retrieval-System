def locate(sub, main):
  size_main = len(main)
  size_sub = len(sub)

  print("Given String:", main)
  print("Search String:", sub)
  print("------------------------")
  found_any = False # Use boolean for clarity
  index = 0
  while index <= size_main - size_sub:
    k = 0
    match_at_current_index = True
    while k < size_sub:
      if main[index + k] != sub[k]:
        match_at_current_index = False
        break
      k += 1

    if match_at_current_index:
        print("Substring exists at position", index)
        found_any = True

    index += 1 # Always increment index to check the next possible starting position

  if not found_any:
      print("Substring not found in given string")

# The example execution part
full_text = "AABAACAADAABAABA"
search_text = "AABA"
locate(search_text, full_text)
